		"cells": [
			{
				"cell_type": "code",
				"metadata": {
					"microsoft": {
						"language": "sparksql"
					},
					"collapsed": false
				},
				"source": [
					"%%sql\n",
					"--Attrition Rate\n",
					"SELECT \n",
					"    'Attrition Rate' as metrics_name, \n",
					"    COUNT(CASE WHEN attrition_flag = 1 THEN 1 END) * 100.0 / COUNT(*) AS metrics_value\n",
					"FROM hranalytics_db.fact_employee_metrics;"
				],
				"execution_count": 2
			},
			{
				"cell_type": "code",
				"metadata": {
					"microsoft": {
						"language": "sparksql"
					},
					"collapsed": false
				},
				"source": [
					"%%sql\n",
					"--Resignation Drivers\n",
					"SELECT exit_reason, COUNT(*) AS cnt\n",
					"FROM hranalytics_db.silver_exit\n",
					"GROUP BY exit_reason\n",
					"ORDER BY cnt DESC;"
				],
				"execution_count": 3
			},
			{
				"cell_type": "code",
				"metadata": {
					"microsoft": {
						"language": "sparksql"
					},
					"collapsed": false
				},
				"source": [
					"%%sql\n",
					"--Engagement Score\n",
					"SELECT AVG(survey_score) AS avg_engagement\n",
					"FROM hranalytics_db.fact_employee_metrics;\n",
					"\n",
					"--eNPS Score\n",
					"SELECT \n",
					"    (COUNT(CASE WHEN survey_score >= 9 THEN 1 END) -\n",
					"     COUNT(CASE WHEN survey_score <= 6 THEN 1 END)) * 100.0 / COUNT(*) AS eNPS\n",
					"FROM hranalytics_db.fact_employee_metrics;\n",
					"\n",
					"--Early Churn Detection\n",
					"SELECT emp_sk\n",
					"FROM hranalytics_db.fact_employee_metrics\n",
					"WHERE rating < 2 AND survey_score < 5;\n",
					""
				],
				"execution_count": 5
			}
		]
	}
